{
  "name": "manifest",
  "version": "0.1.0",
  "private": true,
  "description": "Event-driven fulfillment operations dashboard — track every order from payment webhook to fulfillment.",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:migrate": "pnpm --filter @manifest/db migrate",
    "db:seed": "pnpm --filter @manifest/db seed",
    "db:studio": "pnpm --filter @manifest/db studio",
    "db:generate": "pnpm --filter @manifest/db generate"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.4",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "esbuild", "prisma"],
    "overrides": {
      "ioredis": "5.11.1"
    }
  }
}
