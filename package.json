{
  "name": "manifest",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "author": "Yohanes",
  "description": "Event-driven fulfillment operations dashboard that tracks every order from payment webhook to fulfillment.",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test --concurrency=1",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "turbo run typecheck",
    "db:migrate": "pnpm --filter @manifest/db migrate",
    "db:seed": "pnpm --filter @manifest/db seed",
    "db:studio": "pnpm --filter @manifest/db studio",
    "db:generate": "pnpm --filter @manifest/db generate"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.4",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.60.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ],
    "overrides": {
      "ioredis": "5.11.1"
    }
  }
}
