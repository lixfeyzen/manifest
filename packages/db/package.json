{
  "name": "@manifest/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "migrate:test": "dotenv -e ../../.env.test -- prisma migrate deploy",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "reset": "dotenv -e ../../.env -- prisma migrate reset --force",
    "lint": "echo \"(no lint configured)\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@manifest/shared": "workspace:*",
    "@prisma/client": "^5.20.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.20.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
