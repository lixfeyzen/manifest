# PostgreSQL connection string used by Prisma (api, worker, db package)
DATABASE_URL="postgresql://manifest:manifest@localhost:5432/manifest?schema=public"

# Redis connection string used by BullMQ (api enqueues, worker consumes)
REDIS_URL="redis://localhost:6379"

# Host ports Docker Compose binds to. Override these if 5432/6379 are already
# taken on your machine (then update DATABASE_URL/REDIS_URL ports to match).
POSTGRES_PORT=5432
REDIS_PORT=6379

# REST + GraphQL server port
API_PORT=4000

# Public API base URL the Next.js frontend talks to
NEXT_PUBLIC_API_URL=http://localhost:4000

# Runtime environment: development | test | production
NODE_ENV=development

# Web dev server port (Next.js). Defaults to 3000; override if 3000 is taken.
PORT=3000

# Auth: exact browser origin allowed to send credentialed requests (must match the web app).
WEB_ORIGIN=http://localhost:3000
# Secret used to sign the session cookie (use a strong random value; required in production).
SESSION_SECRET=change-me-to-a-long-random-string
# Shared HMAC secret for payment-webhook signing/verification (provider signs, API verifies).
WEBHOOK_SECRET=change-me-to-a-webhook-secret
