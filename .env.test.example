# Test environment template. Copy to .env.test and adjust ports if needed.
# Uses a SEPARATE database (manifest_test) so tests never touch dev/demo data.
#
#   1. Create the test database once:
#        docker exec manifest-postgres psql -U manifest -c "CREATE DATABASE manifest_test"
#   2. cp .env.test.example .env.test
#   3. pnpm test   (migrations are applied automatically before the suite)

DATABASE_URL="postgresql://manifest:manifest@localhost:5432/manifest_test?schema=public"
REDIS_URL="redis://localhost:6379"
API_PORT=4001
NEXT_PUBLIC_API_URL=http://localhost:4001
NODE_ENV=test
